# Quality Oracle Configuration

# Server
HOST=0.0.0.0
PORT=8002
DEBUG=false
LOG_LEVEL=info

# MongoDB (shared with Assisterr)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=assisterr

# Redis (shared with Assisterr)
REDIS_URL=redis://localhost:6379/1

# LLM Judge - Primary (DeepSeek V3.2 via OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM Judge - Fallback (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# LLM Judge - Question Generation (Claude Sonnet, one-time)
ANTHROPIC_API_KEY=

# API Keys
API_KEY_SALT=change-this-to-random-string

# CORS
CORS_ORIGINS=["http://localhost:3000","https://quality-oracle.assisterr.ai"]

# Evaluation defaults
DEFAULT_EVAL_LEVEL=2
MAX_CONCURRENT_EVALS=5
EVAL_TIMEOUT_SECONDS=120

# Rate limiting
RATE_LIMIT_FREE=10/month
RATE_LIMIT_DEVELOPER=100/month
RATE_LIMIT_TEAM=500/month
