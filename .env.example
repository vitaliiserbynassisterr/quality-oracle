# AgentTrust Configuration

# Server
HOST=0.0.0.0
PORT=8002
DEBUG=false
LOG_LEVEL=info

# MongoDB (shared with Assisterr)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=assisterr

# Redis (shared with Assisterr)
REDIS_URL=redis://localhost:6379/1

# LLM Judge - Primary (DeepSeek V3.2 via OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM Judge - Groq (comma-separated for key rotation on 429)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# LLM Judge - Cerebras (free: 1M TPD, comma-separated for rotation)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# LLM Judge - OpenRouter (free models, comma-separated for rotation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Judge - Question Generation (Claude Sonnet, one-time)
ANTHROPIC_API_KEY=

# API Keys — generate with: openssl rand -hex 32
API_KEY_SALT=change-this-to-random-string

# JWT Attestation Signing (Ed25519)
# Option 1: base64-encoded PEM key as env var (recommended for containers)
#   Generate: base64 -i data/jwt_private_key.pem | tr -d '\n'
JWT_PRIVATE_KEY=
# Option 2: path to PEM file (auto-generates if missing)
JWT_PRIVATE_KEY_PATH=
JWT_ISSUER=did:web:agenttrust.assisterr.ai
ATTESTATION_VALIDITY_DAYS=30

# Payment — Receiver Wallet (Solana address for x402 payments)
# Set to your real Solana wallet address for production
RECEIVER_WALLET_ADDRESS=

# Solana RPC (for payment verification, optional)
SOLANA_RPC_URL=https://api.devnet.solana.com

# CORS
CORS_ORIGINS=["http://localhost:3000","https://agenttrust.assisterr.ai"]

# Evaluation defaults
DEFAULT_EVAL_LEVEL=2
MAX_CONCURRENT_EVALS=5
EVAL_TIMEOUT_SECONDS=120
EVALUATION_VERSION=v1.0

# Rate limiting (evaluations per month)
RATE_LIMIT_FREE=10
RATE_LIMIT_DEVELOPER=100
RATE_LIMIT_TEAM=500

# Webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# Base URL (used in response links, badges, webhooks)
BASE_URL=http://localhost:8002
